{
    "name": "docton-backend",
    "version": "1.0.0",
    "description": "Docton Saúde Backend API",
    "main": "dist/server.js",
    "scripts": {
        "build": "npx prisma generate && (npx tsc --noEmitOnError false || echo 'TSC failed but proceeding') && ([ -f dist/src/server.js ] && cp dist/src/server.js dist/server.js || echo 'Already in root') && ls dist/server.js",
        "start": "node dist/server.js",
        "start:simple": "node dist/server-simple.js",
        "start:intermediate": "node dist/server-intermediate.js",
        "start:ts": "tsx src/server.ts",
        "dev": "tsx watch src/server.ts",
        "dev:simple": "tsx watch src/server-simple.ts",
        "dev:intermediate": "tsx watch src/server-intermediate.ts",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate deploy",
        "lint": "npx tsc --noEmit",
        "test": "echo \"Warning: no test specified\" && exit 0"
    },
    "dependencies": {
        "@prisma/client": "5.22.0",
        "@supabase/supabase-js": "^2.94.1",
        "axios": "^1.7.9",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.37.1",
        "compression": "^1.7.5",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "cross-env": "^7.0.3",
        "date-fns": "^4.1.0",
        "dotenv": "^16.6.1",
        "exceljs": "^4.4.0",
        "express": "^4.21.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^7.3.1",
        "express-validator": "^7.3.1",
        "firebase-admin": "^13.7.0",
        "handlebars": "^4.7.8",
        "helmet": "^8.0.0",
        "hpp": "^0.2.3",
        "http-proxy-middleware": "^3.0.5",
        "i18next": "^23.15.2",
        "i18next-fs-backend": "^2.6.0",
        "i18next-http-backend": "^3.0.2",
        "i18next-http-middleware": "^3.6.0",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^3.0.3",
        "nodemailer": "^6.9.14",
        "openai": "^4.85.2",
        "opossum": "^9.0.0",
        "pdfkit": "^0.17.2",
        "pg": "^8.20.0",
        "qrcode": "^1.5.4",
        "sharp": "^0.33.5",
        "slugify": "^1.6.8",
        "socket.io": "^4.8.1",
        "stripe": "^17.7.0",
        "tesseract.js": "^6.0.1",
        "uuid": "^11.0.5",
        "web-push": "^3.6.7",
        "winston": "^3.17.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.7.5",
        "@types/cookie-parser": "^1.4.8",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/hpp": "^0.2.6",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.13.10",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^6.4.17",
        "@types/pdfkit": "^0.13.6",
        "@types/uuid": "^10.0.0",
        "@types/web-push": "^3.6.4",
        "prisma": "5.22.0",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2"
    },
    "engines": {
        "node": ">=20"
    }
}
