generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AchievementShare {
  id               String     @id @default(cuid())
  patientId        String
  challengeId      String?
  achievementTitle String?
  achievementType  String?
  platform         String?
  imageUrl         String?
  sharedAt         DateTime?  @default(now())
  createdAt        DateTime   @default(now())
  Challenge        Challenge? @relation(fields: [challengeId], references: [id])
  Patient          Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Admin {
  id                   String                 @id @default(cuid())
  userId               String                 @unique
  permissions          String[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  roleId               String?
  Role                 Role?                  @relation(fields: [roleId], references: [id])
  User                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  KnowledgeBaseArticle KnowledgeBaseArticle[]
}

model AiInsight {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        String
  title       String
  description String?
  confidence  Int
  impact      String
  category    String
  data        Json?
  actionable  Boolean?  @default(true)
  priority    Int?      @default(3)
  userId      String?   @db.Uuid
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
}

model AnalyticsEvent {
  id              String   @id @default(cuid())
  event           String
  properties      String?
  propertiesJson  Json?
  personId        String?
  userId          String?
  timestamp       DateTime @default(now())
  timestampBigInt BigInt?
  sessionId       String?
  page            String?
  createdAt       DateTime @default(now())
}

model Anamnesis {
  id              String   @id @default(cuid())
  patientId       String
  date            DateTime
  chiefComplaint  String
  currentIllness  String
  familyHistory   String?
  personalHistory String?
  medications     Json?
  allergies       Json?
  socialHistory   String?
  reviewOfSystems Json?
  vitalSigns      Json?
  physicalExam    String?
  assessment      String?
  plan            String?
  doctorName      String?
  specialty       String?
  attachments     String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  Patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Anomaly {
  id            String        @id @default(cuid())
  type          String
  severity      String
  title         String
  description   String?
  metric        String
  currentValue  Float?
  expectedValue Float?
  deviation     Float?
  confidence    Float?
  detectedAt    DateTime
  status        String
  category      String
  impact        String?
  owner         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  AnomalyNote   AnomalyNote[]
}

model AnomalyModel {
  id                String    @id @default(cuid())
  name              String
  description       String?
  isActive          Boolean   @default(true)
  sensitivity       String
  detectionRate     Float
  falsePositiveRate Float
  lastTrained       DateTime?
  metrics           String[]
}

model AnomalyNote {
  id        String   @id @default(cuid())
  anomalyId String
  at        DateTime
  text      String
  Anomaly   Anomaly  @relation(fields: [anomalyId], references: [id])
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String
  keyHash   String
  keyMasked String?
  scopes    String[]
  createdAt DateTime  @default(now())
  lastUsed  DateTime?
  expiresAt DateTime?
  revoked   Boolean   @default(false)
}

model AppInstallation {
  id        String   @id @default(cuid())
  partnerId String
  platform  String
  version   String
  createdAt DateTime @default(now())
  Partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model Appointment {
  id                String              @id @default(cuid())
  patientId         String
  partnerId         String?
  dateTime          DateTime?
  duration          Int?
  status            String              @default("SCHEDULED")
  isOnline          Boolean             @default(false)
  meetingLink       String?
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  roomId            String?
  equipmentId       String?
  professionalId    String?
  Equipment         Equipment?          @relation(fields: [equipmentId], references: [id])
  Partner           Partner?            @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  Patient           Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  TeamMember        TeamMember?         @relation(fields: [professionalId], references: [id])
  Room              Room?               @relation(fields: [roomId], references: [id])
  MedicalRecord     MedicalRecord?
  PixDeposit        PixDeposit?
  Review            Review?
  ValidationCodeLog ValidationCodeLog[]

  @@index([dateTime])
  @@index([partnerId])
  @@index([patientId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userName   String?
  userRole   String?
  action     String
  resource   String
  resourceId String?
  payload    String?
  details    Json?
  ipAddress  String
  userAgent  String?
  severity   String?
  category   String?
  status     String?
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())
}

model AutomatedReport {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String
  type           String
  frequency      String
  recipients     String[]
  format         String
  isActive       Boolean?  @default(true)
  lastGenerated  DateTime? @db.Timestamptz(6)
  nextGeneration DateTime? @db.Timestamptz(6)
  template       String?
  filters        Json?
  createdAt      DateTime? @default(now()) @db.Timestamptz(6)
}

model AvailabilityRequest {
  id                 String   @id @default(cuid())
  patientId          String
  partnerId          String
  specialty          String
  date               String
  time               String
  urgency            String   @default("normal")
  status             String   @default("pending")
  suggestedSlots     String?
  suggestedSlotsJson Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime
  Partner            Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  Patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Badge {
  id           String         @id @default(cuid())
  name         String
  description  String
  icon         String
  rarity       String
  category     String
  isSecret     Boolean        @default(false)
  points       Int            @default(0)
  criteria     String?
  criteriaJson Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  PatientBadge PatientBadge[]
}

model BlockchainRecord {
  id        String   @id @default(cuid())
  patientId String
  txHash    String   @unique
  dataHash  String
  createdAt DateTime @default(now())
  Patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Challenge {
  id               String             @id @default(cuid())
  title            String
  description      String
  type             String
  points           Int
  icon             String?
  targetValue      Int?
  frequency        String?
  category         String
  difficulty       String?
  estimatedTime    Int?
  isActive         Boolean            @default(true)
  createdBy        String?
  sponsor          String?
  startDate        DateTime?
  endDate          DateTime?
  status           String?            @default("Ativo")
  imageUrl         String?
  approvalStatus   String?            @default("approved")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @default(now())
  AchievementShare AchievementShare[]
  CoachChallenge   CoachChallenge[]
  PatientChallenge PatientChallenge[]
}

model ChatHistory {
  id        String   @id @default(cuid())
  userId    String
  message   String
  response  String
  context   Json?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id       String     @id @default(cuid())
  tenantId String?
  name     String
  Tenant   Tenant?    @relation(fields: [tenantId], references: [id])
  Employee Employee[]
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Message   Message[]
}

model Employee {
  id        String  @id @default(cuid())
  userId    String
  companyId String
  role      String
  Company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  User      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Equipment {
  id          String        @id @default(cuid())
  name        String
  partnerId   String
  status      String        @default("AVAILABLE")
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  Appointment Appointment[]
  Partner     Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model ExamAnalysis {
  id        String   @id @default(cuid())
  userId    String
  examType  String
  finding   String
  summary   String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model FamilyGroup {
  id        String    @id @default(cuid())
  name      String
  ownerId   String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Patient   Patient[]
}

model FavoritePartner {
  id        String   @id @default(cuid())
  patientId String
  partnerId String
  createdAt DateTime @default(now())
  Partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  Patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, partnerId])
}

model HealthExam {
  id              String   @id @default(cuid())
  patientId       String
  date            DateTime
  type            String
  name            String
  doctor          String
  laboratory      String?
  status          String
  results         String?
  referenceValues String?
  interpretation  String?
  attachments     String[] @default([])
  urgency         String   @default("Normal")
  fasting         Boolean  @default(false)
  preparation     String?
  cost            Float?
  healthPlan      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  Patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model HealthLog {
  id              String   @id @default(cuid())
  patientId       String
  type            String
  value           String
  unit            String?
  notes           String?
  logDate         DateTime @default(now())
  createdAt       DateTime @default(now())
  category        String?
  inputs          Json?
  interpretation  String?
  recommendations Json?
  updatedAt       DateTime @default(now()) @updatedAt
  Patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([logDate])
  @@index([patientId])
  @@index([type])
}

model HealthTip {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String?
  isActive  Boolean  @default(true)
  author    String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model InspirationalQuote {
  id          String   @id @default(cuid())
  content     String
  author      String?
  category    String?
  responsavel String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model Integration {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  settings    Json?
}

model JournalEntry {
  id                                                        String        @id @default(cuid())
  transactionId                                             String
  description                                               String
  amount                                                    Float
  debitAccountId                                            String
  creditAccountId                                           String
  metadata                                                  String?
  timestamp                                                 DateTime      @default(now())
  createdAt                                                 DateTime      @default(now())
  LedgerAccount_JournalEntry_creditAccountIdToLedgerAccount LedgerAccount @relation("JournalEntry_creditAccountIdToLedgerAccount", fields: [creditAccountId], references: [id])
  LedgerAccount_JournalEntry_debitAccountIdToLedgerAccount  LedgerAccount @relation("JournalEntry_debitAccountIdToLedgerAccount", fields: [debitAccountId], references: [id])
}

model KnowledgeBaseArticle {
  id                    String                @id @default(cuid())
  title                 String
  slug                  String                @unique
  content               String
  categoryId            String
  authorId              String?
  status                String                @default("DRAFT")
  tags                  String[]
  views                 Int                   @default(0)
  helpful               Int                   @default(0)
  notHelpful            Int                   @default(0)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  Admin                 Admin?                @relation(fields: [authorId], references: [id])
  KnowledgeBaseCategory KnowledgeBaseCategory @relation(fields: [categoryId], references: [id])
}

model KnowledgeBaseCategory {
  id                   String                 @id @default(cuid())
  name                 String                 @unique
  slug                 String                 @unique
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  KnowledgeBaseArticle KnowledgeBaseArticle[]
}

model LedgerAccount {
  id                                                       String         @id @default(cuid())
  personId                                                 String?
  name                                                     String
  type                                                     String
  currency                                                 String         @default("BRL")
  isActive                                                 Boolean        @default(true)
  createdAt                                                DateTime       @default(now())
  updatedAt                                                DateTime
  JournalEntry_JournalEntry_creditAccountIdToLedgerAccount JournalEntry[] @relation("JournalEntry_creditAccountIdToLedgerAccount")
  JournalEntry_JournalEntry_debitAccountIdToLedgerAccount  JournalEntry[] @relation("JournalEntry_debitAccountIdToLedgerAccount")
  Person                                                   Person?        @relation(fields: [personId], references: [id])
}

model LoyaltyCampaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  multiplier  Float    @default(2.0)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model LoyaltyConfig {
  id               String   @id @default(cuid())
  pointsPerReal    Float    @default(5.0)
  onboardingPoints Int      @default(100)
  reviewPoints     Int      @default(50)
  updatedAt        DateTime
}

model LoyaltyTier {
  id        String    @id @default(cuid())
  name      String    @unique
  minPoints Int
  color     String?
  benefits  String[]
  isActive  Boolean   @default(true)
  type      String    @default("DEFAULT")
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime
}

model MedicalHistory {
  id          String   @id @default(cuid())
  patientId   String
  date        DateTime
  type        String
  doctor      String
  specialty   String
  description String
  diagnosis   String?
  treatment   String?
  location    String?
  status      String   @default("Concluído")
  notes       String?
  attachments String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model MedicalQuote {
  id              String    @id @default(cuid())
  patientId       String?
  patientName     String
  patientPhone    String
  examType        String
  urgency         String    @default("normal")
  description     String?
  imageUrl        String?
  status          String    @default("pending")
  partnerId       String?
  crmStatus       String    @default("novo")
  crmNotes        String?
  responsavel     String?
  valorEstimado   Float?
  appointmentDate DateTime?
  proximoContato  DateTime?
  coupon          String?
  crmMotivoPerda  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  Partner         Partner?  @relation(fields: [partnerId], references: [id])
  Patient         Patient?  @relation(fields: [patientId], references: [id])
}

model MedicalRecord {
  id                        String                      @id @default(cuid())
  appointmentId             String                      @unique
  patientId                 String
  partnerId                 String
  diagnosis                 String
  symptoms                  String?
  symptomsArray             String[]                    @default([])
  treatment                 String?
  observations              String?
  attachments               String?
  attachmentsArray          String[]                    @default([])
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime
  ipfsHash                  String?
  txHash                    String?
  isSealed                  Boolean                     @default(false)
  Appointment               Appointment                 @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  Partner                   Partner                     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  Patient                   Patient                     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medical_record_audit_logs medical_record_audit_logs[]
}

model MedicalRecordPermission {
  id                   String    @id @default(cuid())
  patientId            String
  professionalId       String
  appointmentId        String?
  status               String    @default("pending")
  requestedAt          DateTime  @default(now())
  respondedAt          DateTime?
  expiresAt            DateTime?
  reason               String
  permissions          String?
  permissionsJson      Json?
  patientResponse      String?
  patientResponseJson  Json?
  professionalInfo     String?
  professionalInfoJson Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime
  Patient              Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Partner              Partner   @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model MedicationLog {
  id             String    @id @default(cuid())
  patientId      String
  medicationName String
  dosage         String
  scheduledTime  DateTime
  takenTime      DateTime?
  status         String    @default("taken")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  Patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, scheduledTime])
}

model MedicationReminder {
  id             String        @id @default(cuid())
  patientId      String
  prescriptionId String?
  medicationName String
  dosage         String
  times          String[]
  startDate      DateTime
  endDate        DateTime?
  isActive       Boolean       @default(true)
  notes          String?
  lastTaken      DateTime?
  nextDue        DateTime?
  adherenceRate  Float         @default(100)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  Patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Prescription   Prescription? @relation(fields: [prescriptionId], references: [id])
}

model MedicationSubscription {
  id              String    @id @default(cuid())
  patientId       String
  pharmacyId      String?
  medicationName  String
  dosage          String?
  quantity        Int       @default(1)
  frequencyDays   Int       @default(30)
  nextRefillDate  DateTime
  status          String    @default("ACTIVE")
  discountPercent Float     @default(10.0)
  autoRefill      Boolean   @default(true)
  paymentMethod   String?
  lastRefillDate  DateTime?
  totalRefills    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  Patient         Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Pharmacy        Pharmacy? @relation(fields: [pharmacyId], references: [id])

  @@index([nextRefillDate])
  @@index([patientId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  content        String
  sender         String
  createdAt      DateTime     @default(now())
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model NFTCertificate {
  id        String   @id @default(cuid())
  patientId String
  tokenId   String   @unique
  metadata  String
  createdAt DateTime @default(now())
  Patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model NPSResponse {
  id                  String   @id @default(cuid())
  userId              String
  userName            String
  userEmail           String
  planType            String
  daysSinceSignup     Int
  score               Int
  category            String
  qualitativeFeedback String?
  tags                String[]
  triggerContext      String
  timestamp           DateTime @default(now())
  processed           Boolean  @default(false)
  actionTaken         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime
  User                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  personId  String?
  userId    String?
  title     String
  message   String
  type      String?
  read      Boolean  @default(false)
  link      String?
  dataJson  Json?
  priority  String?  @default("medium")
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  status    String      @default("PENDING")
  total     Float       @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime
  User      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  OrderItem OrderItem[]

  @@index([status])
  @@index([userId])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String?
  productName     String
  productCategory String?
  quantity        Int     @default(1)
  price           Float
  Order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Partner {
  id                      String                    @id @default(cuid())
  tenantId                String?
  personId                String?                   @unique
  userId                  String?                   @unique
  name                    String?
  phone                   String?
  photo                   String?
  crm                     String?
  specialty               String?
  specialties             String[]                  @default([])
  institution             String?
  experience              Int?
  experienceYears         Int?
  rating                  Float?
  totalReviews            Int                       @default(0)
  verified                Boolean                   @default(false)
  isApproved              Boolean                   @default(false)
  rejectionReason         String?
  type                    String                    @default("INDIVIDUAL")
  description             String?
  address                 String?
  city                    String?
  state                   String?
  zipCode                 String?
  lat                     Float?
  lng                     Float?
  acceptsEmergency        Boolean                   @default(false)
  acceptsInsurance        Boolean                   @default(false)
  acceptsOnline           Boolean                   @default(false)
  acceptsTelemedicine     Boolean                   @default(false)
  cnpj                    String?
  consultationPrice       Float?
  education               Json?
  facilities              String[]                  @default([])
  foundationYear          Int?
  insurances              String[]                  @default([])
  languages               String[]                  @default([])
  settings                Json?
  workingHours            Json?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  planType                String?                   @default("Gratuito")
  AppInstallation         AppInstallation[]
  Appointment             Appointment[]
  AvailabilityRequest     AvailabilityRequest[]
  Equipment               Equipment[]
  FavoritePartner         FavoritePartner[]
  GrowthInsight           GrowthInsight[]
  MarketingCampaign       MarketingCampaign[]
  MedicalQuote            MedicalQuote[]
  MedicalRecord           MedicalRecord[]
  MedicalRecordPermission MedicalRecordPermission[]
  Person                  Person?                   @relation(fields: [personId], references: [id], onDelete: Cascade)
  Tenant                  Tenant?                   @relation(fields: [tenantId], references: [id])
  User                    User?                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  PartnerBoost            PartnerBoost[]
  PartnerDocument         PartnerDocument[]
  PartnerFinancialData    PartnerFinancialData?
  PartnerGrowthStats      PartnerGrowthStats?
  PartnerService          PartnerService[]
  Prescription            Prescription[]
  Quote                   Quote[]
  Review                  Review[]
  Room                    Room[]
  SupportTicket           SupportTicket[]
  TeamMember              TeamMember[]
  Transaction             Transaction[]
  Transfer                Transfer[]
  ValidationCodeLog       ValidationCodeLog[]

  @@index([institution])
  @@index([specialty])
}

model PartnerDocument {
  id              String   @id @default(cuid())
  partnerId       String
  type            String
  name            String
  url             String
  status          String   @default("PENDING")
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  Partner         Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model PartnerFinancialData {
  id                    String   @id @default(cuid())
  partnerId             String   @unique
