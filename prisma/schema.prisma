generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  domain     String?    @unique
  isActive   Boolean    @default(true)
  settings   String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  companies  Company[]
  partners   Partner[]
  patients   Patient[]
  pharmacies Pharmacy[]
  users      User[]
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userName   String?
  userRole   String?
  action     String
  resource   String
  resourceId String?
  payload    String?
  details    Json?
  ipAddress  String
  userAgent  String?
  severity   String?
  category   String?
  status     String?
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())
}

model Role {
  id              String       @id @default(cuid())
  name            String       @unique
  description     String?
  permissionsJson Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  admins          Admin[]
  permissions     Permission[] @relation("PermissionToRole")
  users           User[]       @relation("RoleToUser")
}

model Permission {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roles     Role[]   @relation("PermissionToRole")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String
  role              String             @default("PATIENT")
  name              String?
  phone             String?
  avatar            String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  department        String?
  emailVerified     Boolean            @default(false)
  jobTitle          String?
  personId          String?            @unique
  pharmacyId        String?
  preferredCurrency String             @default("BRL")
  preferredLanguage String             @default("pt")
  tenantId          String?
  admin             Admin?
  aiInsights        AiInsight[]
  chatHistories     ChatHistory[]
  conversations     Conversation[]
  employees         Employee[]
  examAnalyses      ExamAnalysis[]
  npsResponses      NPSResponse[]
  orders            Order[]
  partner           Partner?           @relation("UserToPartner")
  patient           Patient?           @relation("UserToPatient")
  predictiveAlerts  PredictiveAlert[]
  researcher        Researcher?
  assignedTickets   SupportTicket[]    @relation("AssignedTickets")
  person            Person?            @relation(fields: [personId], references: [id], onDelete: Cascade)
  pharmacy          Pharmacy?          @relation(fields: [pharmacyId], references: [id])
  tenant            Tenant?            @relation(fields: [tenantId], references: [id])
  userProductStats  UserProductStats[]
  roles             Role[]             @relation("RoleToUser")
}

model Person {
  id        String          @id @default(cuid())
  name      String
  phone     String?
  avatar    String?
  metadata  String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  accounts  LedgerAccount[]
  partner   Partner?
  patient   Patient?
  user      User?
  Person_A  Person[]        @relation("Guardian")
  Person_B  Person[]        @relation("Guardian")
}

model Partner {
  id                       String                    @id @default(cuid())
  tenantId                 String?
  personId                 String?                   @unique
  userId                   String?                   @unique
  name                     String?
  phone                    String?
  photo                    String?
  crm                      String?
  specialty                String?
  specialties              String[]                  @default([])
  institution              String?
  experience               Int?
  experienceYears          Int?
  rating                   Float?
  totalReviews             Int                       @default(0)
  verified                 Boolean                   @default(false)
  isApproved               Boolean                   @default(false)
  rejectionReason          String?
  type                     String                    @default("INDIVIDUAL")
  description              String?
  address                  String?
  city                     String?
  state                    String?
  zipCode                  String?
  lat                      Float?
  lng                      Float?
  acceptsEmergency         Boolean                   @default(false)
  acceptsInsurance         Boolean                   @default(false)
  acceptsOnline            Boolean                   @default(false)
  acceptsTelemedicine      Boolean                   @default(false)
  cnpj                     String?
  consultationPrice        Float?
  education                Json?
  facilities               String[]                  @default([])
  foundationYear           Int?
  insurances               String[]                  @default([])
  languages                String[]                  @default([])
  settings                 Json?
  workingHours             Json?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  installations            AppInstallation[]
  appointments             Appointment[]
  availabilityRequests     AvailabilityRequest[]
  equipment                Equipment[]
  favorites                FavoritePartner[]
  medicalQuotes            MedicalQuote[]
  medicalRecords           MedicalRecord[]
  medicalRecordPermissions MedicalRecordPermission[] @relation("PartnerToPermission")
  person                   Person?                   @relation(fields: [personId], references: [id], onDelete: Cascade)
  tenant                   Tenant?                   @relation(fields: [tenantId], references: [id])
  user                     User?                     @relation("UserToPartner", fields: [userId], references: [id], onDelete: Cascade)
  documents                PartnerDocument[]
  financialData            PartnerFinancialData?
  services                 PartnerService[]
  Prescription             Prescription[]
  quotes                   Quote[]
  reports                  Report[]
  reviews                  Review[]
  rooms                    Room[]
  supportTickets           SupportTicket[]
  team                     TeamMember[]
  Transaction              Transaction[]
  transfers                Transfer[]
  validationLogs           ValidationCodeLog[]

  @@index([specialty])
  @@index([institution])
}

model Patient {
  id                       String                    @id @default(cuid())
  createdAt                DateTime                  @default(now())
  address                  String?
  allergies                String[]                  @default([])
  birthDate                DateTime?
  bloodType                String?
  chronicDiseases          String[]                  @default([])
  city                     String?
  cpf                      String?                   @unique
  currentMedications       String[]                  @default([])
  currentStreak            Int                       @default(0)
  emergencyContact         String?
  emergencyPhone           String?
  gender                   String?
  healthPoints             Int                       @default(0)
  lastActiveDate           DateTime?
  level                    Int                       @default(1)
  longestStreak            Int                       @default(0)
  state                    String?
  updatedAt                DateTime                  @updatedAt
  userId                   String?                   @unique
  zipCode                  String?
  archetype                String?                   @default("GENERAL")
  blockchainAddress        String?                   @unique
  dateOfBirth              DateTime?
  encryptionPublicKey      String?
  experiencePoints         Int                       @default(0)
  healthGoals              String[]                  @default([])
  levelTier                String?
  levelTitle               String?
  lifestyle                Json?
  medications              String?
  onboardingCompleted      Boolean                   @default(false)
  personId                 String?                   @unique
  referralCode             String?                   @unique
  referralCount            Int                       @default(0)
  referralEarnings         Float                     @default(0)
  referredBy               String?
  settings                 Json?
  tenantId                 String?
  totalBadgesEarned        Int                       @default(0)
  totalChallengesCompleted Int                       @default(0)
  userIntent               String?
  userPriority             String?
  familyGroupId            String?
  familyRole               String?                   @default("HEAD")
  achievementShares        AchievementShare[]
  anamneses                Anamnesis[]
  appointments             Appointment[]
  availabilityRequests     AvailabilityRequest[]
  blockchainRecords        BlockchainRecord[]
  favoritePartners         FavoritePartner[]
  healthExams              HealthExam[]
  healthLogs               HealthLog[]
  medicalHistories         MedicalHistory[]
  medicalQuotes            MedicalQuote[]
  medicalRecords           MedicalRecord[]
  medicalRecordPermissions MedicalRecordPermission[] @relation("PatientToPermission")
  medicationLogs           MedicationLog[]
  medicationReminders      MedicationReminder[]
  medicationSubscriptions  MedicationSubscription[]
  nftCertificates          NFTCertificate[]
  familyGroup              FamilyGroup?              @relation(fields: [familyGroupId], references: [id])
  person                   Person?                   @relation(fields: [personId], references: [id], onDelete: Cascade)
  tenant                   Tenant?                   @relation(fields: [tenantId], references: [id])
  user                     User?                     @relation("UserToPatient", fields: [userId], references: [id], onDelete: Cascade)
  patientBadges            PatientBadge[]
  patientChallenges        PatientChallenge[]
  dailyTasks               PatientDailyTask[]
  patientGoals             PatientGoal[]
  insights                 PatientInsight[]
  patientRewards           PatientReward[]
  pharmacyCustomers        PharmacyCustomer[]
  pharmacyOrders           PharmacyOrder[]
  pointsHistory            PointsHistory[]
  prescriptions            Prescription[]
  quotationRequests        QuotationRequest[]
  quotes                   Quote[]
  researchEnrollments      ResearchEnrollment[]
  reviews                  Review[]
  subscriptions            Subscription[]
  supportTickets           SupportTicket[]
  symptomAnalyses          SymptomAnalysis[]
  transactions             Transaction[]
  validationLogs           ValidationCodeLog[]
  wearableConnections      WearableConnection[]
  xpTransactions           XPTransaction[]
}

model FamilyGroup {
  id        String    @id @default(cuid())
  name      String
  ownerId   String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  members   Patient[]
}

model Appointment {
  id             String              @id @default(cuid())
  patientId      String
  partnerId      String?
  dateTime       DateTime?
  duration       Int?
  status         String              @default("SCHEDULED")
  isOnline       Boolean             @default(false)
  meetingLink    String?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  roomId         String?
  equipmentId    String?
  professionalId String?
  equipment      Equipment?          @relation(fields: [equipmentId], references: [id])
  partner        Partner?            @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  patient        Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional   TeamMember?         @relation(fields: [professionalId], references: [id])
  room           Room?               @relation(fields: [roomId], references: [id])
  medicalRecord  MedicalRecord?
  pixDeposit     PixDeposit?
  review         Review?
  validationLogs ValidationCodeLog[]

  @@index([patientId])
  @@index([partnerId])
  @@index([dateTime])
  @@index([status])
}

model Transaction {
  id           String    @id @default(cuid())
  description  String
  amount       Float
  type         String
  category     String?
  status       String    @default("COMPLETED")
  date         DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  metadata     String?
  metadataJson Json?
  patientId    String?
  partnerId    String?
  client       String?
  dueDate      DateTime?
  paymentDate  DateTime?
  dreCategory  String?
  partner      Partner?  @relation(fields: [partnerId], references: [id])
  patient      Patient?  @relation(fields: [patientId], references: [id])

  @@index([date])
  @@index([status])
  @@index([partnerId])
  @@index([patientId])
}

model MedicalRecord {
  id               String                  @id @default(cuid())
  appointmentId    String                  @unique
  patientId        String
  partnerId        String
  diagnosis        String
  symptoms         String?
  symptomsArray    String[]                @default([])
  treatment        String?
  observations     String?
  attachments      String?
  attachmentsArray String[]                @default([])
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  ipfsHash         String?
  txHash           String?
  isSealed         Boolean                 @default(false)
  appointment      Appointment             @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  partner          Partner                 @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  patient          Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  auditLogs        MedicalRecordAuditLog[]
}

model Prescription {
  id                String               @id @default(cuid())
  patientId         String
  partnerId         String?
  medication        String?
  dosage            String?
  frequency         String?
  duration          String?
  instructions      String?
  medications       Json?
  sideEffects       String?
  contraindications String?
  category          String?
  validUntil        DateTime?
  doctor            String?
  date              DateTime?            @default(now())
  attachments       String[]             @default([])
  status            String               @default("Ativo")
  startDate         DateTime?
  endDate           DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  reminders         MedicationReminder[]
  partner           Partner?             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  patient           Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model MedicationReminder {
  id             String        @id @default(cuid())
  patientId      String
  prescriptionId String?
  medicationName String
  dosage         String
  times          String[]
  startDate      DateTime
  endDate        DateTime?
  isActive       Boolean       @default(true)
  notes          String?
  lastTaken      DateTime?
  nextDue        DateTime?
  adherenceRate  Float         @default(100)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id])
}

model MedicationLog {
  id             String    @id @default(cuid())
  patientId      String
  medicationName String
  dosage         String
  scheduledTime  DateTime
  takenTime      DateTime?
  status         String    @default("taken")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, scheduledTime])
}

model Review {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  partnerId     String
  patientId     String?
  rating        Int
  comment       String?
  reply         String?
  replyDate     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  partner       Partner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  patient       Patient?    @relation(fields: [patientId], references: [id])
}

model SymptomAnalysis {
  id        String   @id @default(cuid())
  patientId String
  symptoms  Json
  result    Json
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model SupportTicket {
  id            String           @id @default(cuid())
  patientId     String?
  subject       String
  category      String?          @default("General")
  priority      String?          @default("MEDIUM")
  status        String           @default("OPEN")
  rating        Int?
  ratingComment String?
  userEmail     String?
  userName      String?
  assignedToId  String?
  partnerId     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  messages      SupportMessage[]
  assignedTo    User?            @relation("AssignedTickets", fields: [assignedToId], references: [id])
  partner       Partner?         @relation(fields: [partnerId], references: [id])
  patient       Patient?         @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  message   String
  sender    String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model HealthLog {
  id        String   @id @default(cuid())
  patientId String
  type      String
  value     String
  unit      String?
  notes     String?
  logDate   DateTime @default(now())
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([type])
  @@index([logDate])
}

model PatientInsight {
  id           String   @id @default(cuid())
  patientId    String
  type         String
  title        String
  description  String
  priority     String
  category     String?
  actionable   Boolean  @default(false)
  isRead       Boolean  @default(false)
  isDismissed  Boolean  @default(false)
  metadata     String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model HealthExam {
  id              String   @id @default(cuid())
  patientId       String
  date            DateTime
  type            String
  name            String
  doctor          String
  laboratory      String?
  status          String
  results         String?
  referenceValues String?
  interpretation  String?
  attachments     String[] @default([])
  urgency         String   @default("Normal")
  fasting         Boolean  @default(false)
  preparation     String?
  cost            Float?
  healthPlan      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model MedicalHistory {
  id          String   @id @default(cuid())
  patientId   String
  date        DateTime
  type        String
  doctor      String
  specialty   String
  description String
  diagnosis   String?
  treatment   String?
  location    String?
  status      String   @default("Concluído")
  notes       String?
  attachments String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Anamnesis {
  id              String   @id @default(cuid())
  patientId       String
  date            DateTime
  chiefComplaint  String
  currentIllness  String
  familyHistory   String?
  personalHistory String?
  medications     Json?
  allergies       Json?
  socialHistory   String?
  reviewOfSystems Json?
  vitalSigns      Json?
  physicalExam    String?
  assessment      String?
  plan            String?
  doctorName      String?
  specialty       String?
  attachments     String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model PartnerService {
  id                 String           @id @default(cuid())
  partnerId          String
  name               String
  description        String?
  duration           Int
  price              Float
  isOnline           Boolean
  isPresencial       Boolean
  isActive           Boolean          @default(true)
  category           String?
  appointments       Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  basePrice          Float?
  discountBasic      Float            @default(0)
  discountEnterprise Float            @default(0)
  discountPremium    Float            @default(0)
  doctonFeePercent   Float?
  partnerPayout      Float?
  serviceCategoryId  String?
  partner            Partner          @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  serviceCategory    ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])

  @@index([partnerId])
}

model ServiceCategory {
  id            String            @id @default(cuid())
  name          String
  description   String?
  defaultMarkup Float?
  parentId      String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  services      PartnerService[]
  parent        ServiceCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      ServiceCategory[] @relation("CategoryHierarchy")
}

model Quote {
  id              String    @id @default(cuid())
  displayId       Int       @unique @default(autoincrement())
  patientId       String?
  patientName     String
  patientPhone    String
  examType        String
  urgency         String    @default("normal")
  description     String?
  imageUrl        String?
  status          String    @default("pending")
  partnerId       String?
  crmStatus       String    @default("novo")
  crmNotes        String?
  crmNextContact  DateTime?
  crmResponsavel  String?
  crmMotivoPerda  String?
  responsavel     String?
  valorEstimado   Float?
  appointmentDate DateTime?
  proximoContato  DateTime?
  coupon          String?
  discount        Float?    @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  partner         Partner?  @relation(fields: [partnerId], references: [id])
  patient         Patient?  @relation(fields: [patientId], references: [id])
}

model MedicalQuote {
  id              String    @id @default(cuid())
  patientId       String?
  patientName     String
  patientPhone    String
  examType        String
  urgency         String    @default("normal")
  description     String?
  imageUrl        String?
  status          String    @default("pending")
  partnerId       String?
  crmStatus       String    @default("novo")
  crmNotes        String?
  responsavel     String?
  valorEstimado   Float?
  appointmentDate DateTime?
  proximoContato  DateTime?
  coupon          String?
  crmMotivoPerda  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  partner         Partner?  @relation(fields: [partnerId], references: [id])
  patient         Patient?  @relation(fields: [patientId], references: [id])
}

model Plan {
  id            String         @id @default(cuid())
  key           String?        @unique
  name          String
  price         Float
  duration      String?
  interval      String?
  features      String?
  featuresArray String[]
  isActive      Boolean        @default(true)
  description   String?
  ctaLink       String?        @default("#")
  ctaText       String?        @default("Começar")
  displayPrice  String?
  isPopular     Boolean        @default(false)
  order         Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id            String    @id @default(cuid())
  patientId     String
  planId        String
  status        String    @default("ACTIVE")
  paymentMethod String?
  startDate     DateTime?
  startedAt     DateTime? @default(now())
  endDate       DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  plan          Plan      @relation(fields: [planId], references: [id])
}

model Challenge {
  id                String             @id @default(cuid())
  title             String
  description       String
  type              String
  points            Int
  icon              String?
  targetValue       Int?
  frequency         String?
  category          String
  difficulty        String?
  estimatedTime     Int?
  isActive          Boolean            @default(true)
  createdBy         String?
  sponsor           String?
  startDate         DateTime?
  endDate           DateTime?
  status            String?            @default("Ativo")
  imageUrl          String?
  approvalStatus    String?            @default("approved")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  achievementShares AchievementShare[]
  patientChallenges PatientChallenge[]
}

model PatientChallenge {
  id          String    @id @default(cuid())
  patientId   String
  challengeId String
  status      String
  progress    Int
  startDate   DateTime
  completedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([status])
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model PointsHistory {
  id           String   @id @default(cuid())
  patientId    String
  points       Int
  action       String
  description  String?
  metadata     String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Badge {
  id            String         @id @default(cuid())
  name          String
  description   String
  icon          String
  rarity        String
  category      String
  isSecret      Boolean        @default(false)
  points        Int            @default(0)
  criteria      String?
  criteriaJson  Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  patientBadges PatientBadge[]
}

model PatientBadge {
  id         String   @id @default(cuid())
  patientId  String
  badgeId    String
  unlockedAt DateTime @default(now())
  badge      Badge    @relation(fields: [badgeId], references: [id])
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model WearableConnection {
  id               String    @id @default(cuid())
  patientId        String
  platform         String
  connected        Boolean   @default(false)
