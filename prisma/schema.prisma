  healthIntents            HealthIntent[]
  SymptomAnalysis          SymptomAnalysis[]
  transactions             Transaction[]
  validationLogs           ValidationCodeLog[]
  wearableConnections      WearableConnection[]
  xpTransactions           XPTransaction[]
  CrmLead                  CrmLead[]
}

model Pharmacy {
  id                          String                        @id @default(cuid())
  economicGroupId             String?                       @map("tenantId")
  name                        String
  address                     String?
  acceptedPayments            String[]                      @default(["PIX", "CREDIT_CARD", "CASH"])
  averagePriceVsMarket        Float                         @default(1.0)
  averageResponseTimeMinutes  Float                         @default(0)
  city                        String?
  cnpj                        String?
  commissionPercent           Float                         @default(10.0)
  createdAt                   DateTime                      @default(now())
  deliveryFee                 Float?
  deliveryMinOrder            Float?                        @default(0)
  deliveryRadius              Float?
  deliveryTimeAvg             Int?
  distanceScore               Float                         @default(0)
  email                       String?
  hasDelivery                 Boolean                       @default(false)
  isActive                    Boolean                       @default(true)
  isApproved                  Boolean                       @default(false)
  lat                         Float?
  lng                         Float?
  openingHours                String?
  performanceScore            Float                         @default(0)
  phone                       String?
  planScore                   Float                         @default(0)
  priceCompetitivenessScore   Float                         @default(0)
  reasonSocial                String?
  responseRateScore           Float                         @default(0)
  responseTimeScore           Float                         @default(0)
  scoreUpdatedAt              DateTime?
  state                       String?
  totalQuotesReceived         Int                           @default(0)
  totalQuotesResponded        Int                           @default(0)
  updatedAt                   DateTime                      @updatedAt
  whatsapp                    String?
  coverImage                  String?
  logo                        String?
  neighborhood                String?
  zipCode                     String?
  MedicationSubscription      MedicationSubscription[]
  EconomicGroup               EconomicGroup?                @relation(fields: [economicGroupId], references: [id])
  PharmacyCustomer            PharmacyCustomer[]
  metrics                     PharmacyMetric[]
  orders                      PharmacyOrder[]
  PharmacyPerformanceSnapshot PharmacyPerformanceSnapshot[]
  PharmacyProduct             PharmacyProduct[]
  promotions                  PharmacyPromotion[]
  QuotationResponse           QuotationResponse[]
  User                        User[]
  MarketingCampaign           MarketingCampaign[]
  GrowthInsight               GrowthInsight[]
  units                       Unit[]
}

model PharmacyCustomer {
  id         String    @id @default(cuid())
  pharmacyId String
  patientId  String
  orderCount Int       @default(0)
  totalSpent Float     @default(0)
  isVIP      Boolean   @default(false)
  lastOrder  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  Patient    Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Pharmacy   Pharmacy  @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([pharmacyId, patientId])
}

model PharmacyOrderItem {
  id              String          @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int             @default(1)
  price           Float
  PharmacyOrder   PharmacyOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  PharmacyProduct PharmacyProduct @relation(fields: [productId], references: [id])
}

model PharmacyPerformanceSnapshot {
  id                         String   @id @default(cuid())
  pharmacyId                 String
  responseTimeScore          Float    @default(0)
  responseRateScore          Float    @default(0)
  priceCompetitivenessScore  Float    @default(0)
  distanceScore              Float    @default(0)
  planScore                  Float    @default(0)
  overallScore               Float    @default(0)
  totalQuotesReceived        Int      @default(0)
  totalQuotesResponded       Int      @default(0)
  averageResponseTimeMinutes Float    @default(0)
  averagePriceVsMarket       Float    @default(1.0)
  regionalAveragePrice       Float    @default(0)
  competitorCount            Int      @default(0)
  marketShare                Float    @default(0)
  date                       DateTime @default(now())
  createdAt                  DateTime @default(now())
  Pharmacy                   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([pharmacyId])
}

model PharmacyProduct {
  id                String              @id @default(cuid())
  pharmacyId        String
  name              String
  category          String
  brand             String?
  lab               String?
  barcode           String?
  sku               String?
  description       String?
  price             Float
  promotionPrice    Float?
  stock             Int                 @default(0)
  stockMin          Int                 @default(0)
  validity          DateTime?
  batch             String?
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  PharmacyOrderItem PharmacyOrderItem[]
  Pharmacy          Pharmacy            @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
}

model Prescription {
  id                String               @id @default(cuid())
  patientId         String
  partnerId         String?
  medication        String?
  dosage            String?
  frequency         String?
  duration          String?
  instructions      String?
  medications       Json?
  sideEffects       String?
  contraindications String?
  category          String?
  validUntil        DateTime?
  doctor            String?
  date              DateTime?            @default(now())
  attachments       String[]             @default([])
  status            String               @default("Ativo")
  startDate         DateTime?
  endDate           DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  reminders         MedicationReminder[]
  Partner           Partner?             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  Patient           Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model QuotationPayment {
  id                String            @id @default(cuid())
  quotationId       String            @unique
  responseId        String            @unique
  patientId         String
  amount            Float
  status            String            @default("PENDING")
  asaasId           String?
  paymentMethod     String?
  pixQrCode         String?
  pixCopyPaste      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  paymentUrl        String?
  QuotationRequest  QuotationRequest  @relation(fields: [quotationId], references: [id])
  QuotationResponse QuotationResponse @relation(fields: [responseId], references: [id])
}

model QuotationRequest {
  id                   String                 @id @default(cuid())
  patientId            String
  medicamentName       String?
  quantity             Int                    @default(1)
  description          String?
  imageUrl             String?
  status               String                 @default("OPEN")
  lat                  Float?
  lng                  Float?
  maxDistanceKm        Float?                 @default(10)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deliveryType         String?                @default("DELIVERY")
  genericPreference    String?                @default("ACCEPT")
  type                 String?                @default("MANUAL")
  urgency              String?                @default("NORMAL")
  QuotationPayment     QuotationPayment?
  Patient              Patient                @relation(fields: [patientId], references: [id])
  QuotationRequestItem QuotationRequestItem[]
  QuotationResponse    QuotationResponse[]
}

model QuotationRequestItem {
  id               String           @id @default(cuid())
  quotationId      String
  name             String
  dosage           String?
  form             String?
  quantity         Int              @default(1)
  QuotationRequest QuotationRequest @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model QuotationResponse {
  id                    String                  @id @default(cuid())
  quotationId           String
  pharmacyId            String
  price                 Float
  isAvailable           Boolean                 @default(true)
  deliveryTimeMin       Int?
  observations          String?
  status                String                  @default("PENDING")
  responseTimeSec       Int?
  createdAt             DateTime                @default(now())
  expirationTime        DateTime?
  itemsMatched          Int?                    @default(0)
  QuotationPayment      QuotationPayment?
  Pharmacy              Pharmacy                @relation(fields: [pharmacyId], references: [id])
  QuotationRequest      QuotationRequest        @relation(fields: [quotationId], references: [id])
  QuotationResponseItem QuotationResponseItem[]
}

model QuotationResponseItem {
  id                String            @id @default(cuid())
  responseId        String
  name              String
  price             Float
  isGeneric         Boolean           @default(false)
  QuotationResponse QuotationResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
}

model SymptomAnalysis {
  id        String   @id @default(cuid())
  patientId String
  symptoms  Json
  result    Json
  createdAt DateTime @default(now())
  Patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String
  role              String             @default("PATIENT")
  name              String?
  phone             String?
  avatar            String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  department        String?
  emailVerified     Boolean            @default(false)
  jobTitle          String?
  personId          String?            @unique
  pharmacyId        String?
  preferredCurrency String             @default("BRL")
  preferredLanguage String             @default("pt")
  economicGroupId   String?            @map("tenantId")
  Admin             Admin?
