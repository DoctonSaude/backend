  falsePositiveRate Float
  lastTrained       DateTime?
  metrics           String[]
}

model WorkflowRule {
  id             String    @id @default(cuid())
  name           String
  description    String?
  trigger        Json
  actions        Json
  isActive       Boolean   @default(true)
  executionCount Int       @default(0)
  lastExecuted   DateTime?
  createdAt      DateTime  @default(now())
  category       String
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String
  keyHash   String
  keyMasked String?
  scopes    String[]
  createdAt DateTime  @default(now())
  lastUsed  DateTime?
  expiresAt DateTime?
  revoked   Boolean   @default(false)
}

model Integration {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  settings    Json?
}

model Webhook {
  id        String   @id @default(cuid())
  url       String
  secret    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AiInsight {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String?
  confidence  Int
  impact      String
  category    String
  data        Json?
  actionable  Boolean  @default(true)
  priority    Int      @default(3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  status    String      @default("PENDING")
  total     Float       @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     OrderItem[]

  @@index([status])
  @@index([userId])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String?
  productName     String
  productCategory String?
  quantity        Int     @default(1)
  price           Float
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model UserProductStats {
  id                  String    @id @default(cuid())
  userId              String
  productId           String?
  productName         String?
  lastPurchaseDate    DateTime?
  averageIntervalDays Float?    @default(0)
  purchaseCount       Int       @default(0)
  isRecurring         Boolean   @default(false)
  confidenceScore     Float     @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRecurring])
}

model QuotationRequest {
  id             String              @id @default(cuid())
  patientId      String
  medicamentName String
  quantity       Int                 @default(1)
  description    String?
  imageUrl       String?
  status         String              @default("OPEN")
  lat            Float?
  lng            Float?
  maxDistanceKm  Float?              @default(10)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  patient        Patient             @relation(fields: [patientId], references: [id])
  responses      QuotationResponse[]
}

model QuotationResponse {
  id              String           @id @default(cuid())
  quotationId     String
  pharmacyId      String
  price           Float
  isAvailable     Boolean          @default(true)
  deliveryTimeMin Int?
  observations    String?
  status          String           @default("PENDING")
  responseTimeSec Int?
  createdAt       DateTime         @default(now())
  pharmacy        Pharmacy         @relation(fields: [pharmacyId], references: [id])
  quotation       QuotationRequest @relation(fields: [quotationId], references: [id])
}

model PharmacyPromotion {
  id             String   @id @default(cuid())
  pharmacyId     String
  title          String
  description    String?
  originalPrice  Float?
  promotionPrice Float
  imageUrl       String?
  startDate      DateTime
  endDate        DateTime
  isBoosted      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  pharmacy       Pharmacy @relation(fields: [pharmacyId], references: [id])
}

model PharmacyMetric {
  id         String   @id @default(cuid())
  pharmacyId String
  type       String
  value      Float
  metadata   Json?
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id])
}

model PharmacyPerformanceSnapshot {
  id                         String   @id @default(cuid())
  pharmacyId                 String
  responseTimeScore          Float    @default(0)
  responseRateScore          Float    @default(0)
  priceCompetitivenessScore  Float    @default(0)
  distanceScore              Float    @default(0)
  planScore                  Float    @default(0)
  overallScore               Float    @default(0)
  totalQuotesReceived        Int      @default(0)
  totalQuotesResponded       Int      @default(0)
  averageResponseTimeMinutes Float    @default(0)
  averagePriceVsMarket       Float    @default(1.0)
  regionalAveragePrice       Float    @default(0)
  competitorCount            Int      @default(0)
  marketShare                Float    @default(0)
  date                       DateTime @default(now())
  createdAt                  DateTime @default(now())
  pharmacy                   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId])
  @@index([date])
}
