generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DATABASE_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

model EconomicGroup {
  id            String  @id @default(cuid())
  name          String
  slug          String  @unique
  domain        String? @unique
  isActive      Boolean @default(true)
  cnpj          String?
  corporateName String?
  logoUrl       String?
  status        String  @default("ACTIVE")

  settings  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  companies Company[]
  Partner   Partner[]
  Patient   Patient[]
  Pharmacy  Pharmacy[]
  User      User[]
  crmLeads  CrmLead[]

  @@map("Tenant")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userName   String?
  userRole   String?
  action     String
  resource   String
  resourceId String?
  payload    String?
  details    Json?
  ipAddress  String
  userAgent  String?
  severity   String?
  category   String?
  status     String?
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())
}

model Role {
  id              String       @id @default(cuid())
  name            String       @unique
  description     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  permissionsJson Json?
  Admin           Admin[]
  permissions     Permission[] @relation("PermissionToRole")
  users           User[]       @relation("RoleToUser")
}

model Permission {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roles     Role[]   @relation("PermissionToRole")
}

model Person {
  id        String          @id @default(cuid())
  name      String
  phone     String?
  avatar    String?
  metadata  String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  accounts  LedgerAccount[]
  Partner   Partner?
  Patient   Patient?
  User      User?
  Person_A  Person[]        @relation("Guardian")
  Person_B  Person[]        @relation("Guardian")
}

model Transaction {
  id           String    @id @default(cuid())
  description  String
  amount       Float
  type         String
  category     String?
  status       String    @default("COMPLETED")
  date         DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  metadata     String?
  metadataJson Json?
  patientId    String?
  partnerId    String?
  client       String?
  dueDate      DateTime?
  paymentDate  DateTime?
  dreCategory  String?
  partner      Partner?  @relation(fields: [partnerId], references: [id])
  patient      Patient?  @relation(fields: [patientId], references: [id])

  @@index([date])
  @@index([status])
  @@index([partnerId])
  @@index([patientId])
}

model MedicalRecord {
  id               String                  @id @default(cuid())
  appointmentId    String                  @unique
  patientId        String
  partnerId        String
  diagnosis        String
  symptoms         String?
  symptomsArray    String[]                @default([])
  treatment        String?
  observations     String?
  attachments      String?
  attachmentsArray String[]                @default([])
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  ipfsHash         String?
  txHash           String?
  isSealed         Boolean                 @default(false)
  appointment      Appointment             @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  partner          Partner?                @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  patient          Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  auditLogs        MedicalRecordAuditLog[]
}

model MedicationReminder {
  id             String        @id @default(cuid())
  patientId      String
  prescriptionId String?
  medicationName String
  dosage         String
  times          String[]
  startDate      DateTime
  endDate        DateTime?
  isActive       Boolean       @default(true)
  notes          String?
  lastTaken      DateTime?
  nextDue        DateTime?
  adherenceRate  Float         @default(100)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id])
}

model Review {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  partnerId     String
  patientId     String?
  rating        Int
  comment       String?
  reply         String?
  replyDate     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  partner       Partner?    @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  patient       Patient?    @relation(fields: [patientId], references: [id])
}

model SupportTicket {
  id            String           @id @default(cuid())
  patientId     String?
  subject       String
  category      String?          @default("General")
  priority      String?          @default("MEDIUM")
  status        String           @default("OPEN")
  rating        Int?
  ratingComment String?
  userEmail     String?
  userName      String?
  assignedToId  String?
  partnerId     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  messages      SupportMessage[]
  assignedTo    User?            @relation("AssignedTickets", fields: [assignedToId], references: [id])
  partner       Partner?         @relation(fields: [partnerId], references: [id])
  patient       Patient?         @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  message   String
  sender    String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model HealthLog {
  id        String   @id @default(cuid())
  patientId String
  type      String
  value     String
  unit      String?
  notes     String?
  logDate   DateTime @default(now())
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([type])
  @@index([logDate])
}

model HealthCalculation {
  id              String   @id @default(cuid())
  patientId       String
  type            String // BMI, BODY_SURFACE_AREA, CREATININE_CLEARANCE, CARDIAC_RISK, IDEAL_WEIGHT
  value           String
  unit            String
  interpretation  String?
  category        String?
  recommendations String[] @default([])
  inputs          Json?
  logDate         DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([type])
  @@index([logDate])
}

model PatientInsight {
  id           String   @id @default(cuid())
  patientId    String
  type         String
  title        String
  description  String
  priority     String
  category     String?
  actionable   Boolean  @default(false)
  isRead       Boolean  @default(false)
  isDismissed  Boolean  @default(false)
  metadata     String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model SymptomAlert {
  id          String    @id @default(cuid())
  patientId   String
  title       String
  description String
  severity    String    @default("media")
  category    String    @default("geral")
  isActive    Boolean   @default(true)
  isResolved  Boolean   @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@index([patientId, isResolved])
}

model HealthExam {
  id              String   @id @default(cuid())
  patientId       String
  date            DateTime
  type            String
  name            String
  doctor          String
  laboratory      String?
  status          String
  results         String?
  referenceValues String?
  interpretation  String?
  attachments     String[] @default([])
  urgency         String   @default("Normal")
  fasting         Boolean  @default(false)
  preparation     String?
  cost            Float?
  healthPlan      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model MedicalHistory {
  id          String   @id @default(cuid())
  patientId   String
  date        DateTime
  type        String
  doctor      String
  specialty   String
  description String
  diagnosis   String?
  treatment   String?
  location    String?
  status      String   @default("Concluído")
  notes       String?
  attachments String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Anamnesis {
  id              String   @id @default(cuid())
  patientId       String
  date            DateTime
  chiefComplaint  String
  currentIllness  String
  familyHistory   String?
  personalHistory String?
  medications     Json?
  allergies       Json?
  socialHistory   String?
  reviewOfSystems Json?
  vitalSigns      Json?
  physicalExam    String?
  assessment      String?
  plan            String?
  doctorName      String?
  specialty       String?
  attachments     String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model PartnerService {
  id                 String           @id @default(cuid())
  partnerId          String
  name               String
  description        String?
  duration           Int
  price              Float
  isOnline           Boolean
  isPresencial       Boolean
  isActive           Boolean          @default(true)
  category           String?
  appointments       Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  basePrice          Float?
  discountBasic      Float            @default(0)
  discountEnterprise Float            @default(0)
  discountPremium    Float            @default(0)
  doctonFeePercent   Float?
  partnerPayout      Float?
  serviceCategoryId  String?
  partner            Partner?         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  serviceCategory    ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])

  @@index([partnerId])
}

model ServiceCategory {
  id            String            @id @default(cuid())
  name          String
  description   String?
  defaultMarkup Float?
  parentId      String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  services      PartnerService[]
  parent        ServiceCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      ServiceCategory[] @relation("CategoryHierarchy")
}

model Quote {
  id              String    @id @default(cuid())
  displayId       Int       @unique @default(autoincrement())
  patientId       String?
  patientName     String
  patientPhone    String
  examType        String
  urgency         String    @default("normal")
  description     String?
  imageUrl        String?
  status          String    @default("pending")
  partnerId       String?
  crmStatus       String    @default("novo")
  crmNotes        String?
  crmNextContact  DateTime?
  crmResponsavel  String?
  crmMotivoPerda  String?
  responsavel     String?
  valorEstimado   Float?
  appointmentDate DateTime?
  proximoContato  DateTime?
  coupon          String?
  discount        Float?    @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  partner         Partner?  @relation(fields: [partnerId], references: [id])
  patient         Patient?  @relation(fields: [patientId], references: [id])
}

model MedicalQuote {
  id              String    @id @default(cuid())
  patientId       String?
  patientName     String
  patientPhone    String
  examType        String
  urgency         String    @default("normal")
  description     String?
  imageUrl        String?
  status          String    @default("pending")
  partnerId       String?
  crmStatus       String    @default("novo")
  crmNotes        String?
  responsavel     String?
  valorEstimado   Float?
  appointmentDate DateTime?
  proximoContato  DateTime?
  coupon          String?
  crmMotivoPerda  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  partner         Partner?  @relation(fields: [partnerId], references: [id])
  patient         Patient?  @relation(fields: [patientId], references: [id])
}

model Plan {
  id            String         @id @default(cuid())
  key           String?        @unique
  name          String
  price         Float
  duration      String?
  interval      String?
  features      String?
  featuresArray String[]
  isActive      Boolean        @default(true)
  description   String?
  ctaLink       String?        @default("#")
  ctaText       String?        @default("Começar")
  displayPrice  String?
  isPopular     Boolean        @default(false)
  order         Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id            String    @id @default(cuid())
  patientId     String
  planId        String
  status        String    @default("ACTIVE")
  paymentMethod String?
  startDate     DateTime?
  startedAt     DateTime? @default(now())
  endDate       DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  plan          Plan      @relation(fields: [planId], references: [id])
}

model Challenge {
  id                String             @id @default(cuid())
  title             String
  description       String
  type              String
  points            Int
  icon              String?
  targetValue       Int?
  frequency         String?
  category          String
  difficulty        String?
  estimatedTime     Int?
  isActive          Boolean            @default(true)
  createdBy         String?
  sponsor           String?
  startDate         DateTime?
  endDate           DateTime?
  status            String?            @default("Ativo")
  imageUrl          String?
  approvalStatus    String?            @default("approved")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  achievementShares AchievementShare[]
  patientChallenges PatientChallenge[]
}

model PatientChallenge {
  id          String    @id @default(cuid())
  patientId   String
  challengeId String
  status      String
  progress    Int
  startDate   DateTime
  completedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([status])
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model PointsHistory {
  id           String   @id @default(cuid())
  patientId    String
  points       Int
  action       String
  description  String?
  metadata     String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Badge {
  id            String         @id @default(cuid())
  name          String
  description   String
  icon          String
  rarity        String
  category      String
  isSecret      Boolean        @default(false)
  points        Int            @default(0)
  criteria      String?
  criteriaJson  Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  patientBadges PatientBadge[]
}


model PatientBadge {
  id         String   @id @default(cuid())
  patientId  String
  badgeId    String
  unlockedAt DateTime @default(now())
  badge      Badge    @relation(fields: [badgeId], references: [id])
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model WearableConnection {
  id               String    @id @default(cuid())
  patientId        String
  platform         String
  connected        Boolean   @default(false)
  connectedAt      DateTime  @default(now())
  lastSync         DateTime  @default(now())
  permissions      String?
  permissionsArray String[]  @default([])
  accessToken      String?
  refreshToken     String?
  tokenExpiry      DateTime?
  patient          Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, platform])
}

model Reward {
  id              String          @id @default(cuid())
  name            String
  description     String
  icon            String?
  imageUrl        String?
  pointsCost      Int
  category        String
  isActive        Boolean         @default(true)
  status          String          @default("Ativo")
  stockQuantity   Int?
  discountPercent Int?
  partnerInfo     Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  patientRewards  PatientReward[]
}

model PatientReward {
  id         String    @id @default(cuid())
  patientId  String
  rewardId   String
  redeemedAt DateTime  @default(now())
  usedAt     DateTime?
  isUsed     Boolean   @default(false)
  code       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  patient    Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reward     Reward    @relation(fields: [rewardId], references: [id])
}

model AchievementShare {
  id               String     @id @default(cuid())
  patientId        String
  challengeId      String?
  achievementTitle String?
  achievementType  String?
  platform         String?
  imageUrl         String?
  sharedAt         DateTime?  @default(now())
  createdAt        DateTime   @default(now())
  challenge        Challenge? @relation(fields: [challengeId], references: [id])
  patient          Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model LedgerAccount {
  id        String         @id @default(cuid())
  personId  String?
  name      String
  type      String
  currency  String         @default("BRL")
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  credits   JournalEntry[] @relation("CreditAccount")
  debits    JournalEntry[] @relation("DebitAccount")
  person    Person?        @relation(fields: [personId], references: [id])
}

model JournalEntry {
  id              String        @id @default(cuid())
  transactionId   String
  description     String
  amount          Float
  debitAccountId  String
  creditAccountId String
  metadata        String?
  timestamp       DateTime      @default(now())
  createdAt       DateTime      @default(now())
  creditAccount   LedgerAccount @relation("CreditAccount", fields: [creditAccountId], references: [id])
  debitAccount    LedgerAccount @relation("DebitAccount", fields: [debitAccountId], references: [id])
}

model MedicalRecordAuditLog {
  id              String        @id @default(cuid())
  medicalRecordId String
  accessorId      String
  accessorRole    String
  action          String
  timestamp       DateTime      @default(now())
  metadata        String?
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@map("medical_record_audit_logs")
}

model MedicalRecordPermission {
  id                   String    @id @default(cuid())
  patientId            String
  professionalId       String
  appointmentId        String?
  status               String    @default("pending")
  requestedAt          DateTime  @default(now())
  respondedAt          DateTime?
  expiresAt            DateTime?
  reason               String
  permissions          String?
  permissionsJson      Json?
  patientResponse      String?
  patientResponseJson  Json?
  professionalInfo     String?
  professionalInfoJson Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  patient              Patient   @relation("PatientToPermission", fields: [patientId], references: [id], onDelete: Cascade)
  professional         Partner   @relation("PartnerToPermission", fields: [professionalId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id                   String        @id @default(cuid())
  partnerId            String
  name                 String
  specialty            String
  crm                  String?
  isActive             Boolean       @default(true)
  avatar               String?
  email                String?
  phone                String?
  commissionPercentage Float         @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  Appointment          Appointment[]
  partner              Partner?      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model PartnerDocument {
  id              String   @id @default(cuid())
  partnerId       String
  type            String
  name            String
  url             String
  status          String   @default("PENDING")
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  partner         Partner? @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model FavoritePartner {
  id        String   @id @default(cuid())
  patientId String
  partnerId String
  createdAt DateTime @default(now())
  partner   Partner? @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, partnerId])
}

model AvailabilityRequest {
  id                 String   @id @default(cuid())
  patientId          String
  partnerId          String
  specialty          String
  date               String
  time               String
  urgency            String   @default("normal")
  status             String   @default("pending")
  suggestedSlots     String?
  suggestedSlotsJson Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  partner            Partner? @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model ValidationCodeLog {
  id            String       @id @default(cuid())
  code          String
  status        String
  timestamp     DateTime     @default(now())
  partnerId     String?
  patientId     String?
  appointmentId String?
  partnerName   String?
  patientName   String?
  errorMessage  String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  partner       Partner?     @relation(fields: [partnerId], references: [id])
  patient       Patient?     @relation(fields: [patientId], references: [id])
}

model Transfer {
  id           String    @id @default(cuid())
  partnerId    String?
  partnerName  String
  partnerEmail String
  amount       Float
  status       String    @default("PENDING")
  type         String
  receiptUrl   String?
  scheduledFor DateTime?
  processedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  partner      Partner?  @relation(fields: [partnerId], references: [id])
}

model PartnerFinancialData {
  id                    String   @id @default(cuid())
  partnerId             String   @unique
  bankCode              String
  bankName              String
  agency                String
  accountNumber         String
  accountType           String
  accountHolder         String
  taxId                 String
  taxIdType             String
  stateRegistration     String?
  billingAddress        String
  billingCity           String
  billingState          String
  billingZipCode        String
  platformFeePercentage Int      @default(20)
  paymentFrequency      String?
  paymentMethod         String?
  pixKey                String?
  pixKeyType            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  partner               Partner? @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model PatientDailyTask {
  id        String   @id @default(cuid())
  patientId String
  task      String
  xp        Int      @default(50)
  icon      String?
  completed Boolean  @default(false)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, date])
}

model XPTransaction {
  id          String   @id @default(cuid())
  patientId   String
  actionId    String?
  actionName  String?
  baseXP      Int
  bonusXP     Int      @default(0)
  finalXP     Int?
  multipliers Json?
  context     Json?
  reason      String?
  createdAt   DateTime @default(now())
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model LoyaltyTier {
  id        String    @id @default(cuid())
  name      String    @unique
  minPoints Int
  color     String?
  benefits  String[]
  isActive  Boolean   @default(true)
